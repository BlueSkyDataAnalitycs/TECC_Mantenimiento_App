# Copia este archivo a .env y rellena con TUS credenciales de Flypass.
# El .env NO se sube (está gitignored). Las credenciales del "WS cert" van AQUÍ, nunca en la app pública.

FLYPASS_CLIENT_ID=tu_client_id_aqui
FLYPASS_USERNAME=tu_usuario_aqui
FLYPASS_PASSWORD=tu_password_aqui

# NIT de la empresa SIN dígito de verificación. TECC = 800126547
FLYPASS_DOCUMENT=800126547

# Ambiente: cert (pruebas) | prod (producción). Empieza en cert.
FLYPASS_ENV=cert

# Puerto local del proxy
PORT=8088

# En producción restringe el origen al de la app publicada:
# ALLOW_ORIGIN=https://blueskydataanalitycs.github.io
ALLOW_ORIGIN=*
